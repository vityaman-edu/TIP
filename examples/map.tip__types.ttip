map(l,f,z): (⭡μx4.⭡x4,(int) -> int,int) -> int
{
var r: int;
if ((l == null)) {
r = z;
} else {
r = f(map((*l),f,z));
}
return r;
}

foo(i): (int) -> int
{
return (i + 1);
}

main(): () -> int
{
var h: ⭡μx4.⭡x4,t: μx4.⭡x4,n: int;
t = null;
n = 42;
while ((n > 0)) {
n = (n - 1);
h = alloc null;
*h = t;
t = h;
}
return map(h,foo,0);
}